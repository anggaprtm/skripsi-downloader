# ============================================================
# Skripsi Downloader — environment configuration
# Copy to ".env" before running: cp .env.example .env
# ============================================================

# --- General ---
APP_NAME=Skripsi Downloader
DEBUG=false
LOG_LEVEL=INFO

# --- Ports exposed on the host ---
BACKEND_PORT=8000
FRONTEND_PORT=8080

# --- API / CORS ---
# Comma separated list of allowed origins for the browser.
CORS_ORIGINS=http://localhost:8080,http://localhost:5173

# --- Redis / Queue ---
# Inside docker-compose this is overridden to redis://redis:6379/0
REDIS_URL=redis://localhost:6379/0
QUEUE_NAME=skripsi
JOB_TIMEOUT=3600
JOB_TTL=86400

# --- Storage ---
STORAGE_ROOT=/data
JOB_RETENTION_HOURS=24

# --- Downloader ---
DEFAULT_DOWNLOAD_THREADS=20
DOWNLOAD_RETRIES=3
DOWNLOAD_TIMEOUT=30

# --- OCR ---
DEFAULT_OCR_LANGUAGES=ind+eng
OCR_JOBS=2
